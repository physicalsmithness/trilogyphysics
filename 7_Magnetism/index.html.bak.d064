<!doctype html>
<html lang="en">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-WKYGJYERSR"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-WKYGJYERSR');
</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Trilogy Quiz — Magnetism & electromagnetism</title>
<link rel="stylesheet" href="styles.css" />
<!-- GA4 interaction tracking -->
<script>
(function () {
  if (window.__ga4InteractionTrackingInstalled) return;
  window.__ga4InteractionTrackingInstalled = true;

  var trackableSelector = 'a, button, input, select, textarea, summary, [role="button"], [role="link"], [role="tab"], [role="menuitem"], [data-ga4-click], [onclick]';
  var maxLength = 120;

  function clean(value, limit) {
    var text = String(value || '').replace(/\s+/g, ' ').trim();
    return text.slice(0, limit || maxLength);
  }

  function getLabel(element) {
    if (!element) return '';
    var tag = (element.tagName || '').toLowerCase();
    var type = (element.getAttribute('type') || '').toLowerCase();
    if ((tag === 'input' || tag === 'textarea') && !/^(button|submit|reset|checkbox|radio)$/.test(type)) {
      return clean(element.getAttribute('aria-label') || element.getAttribute('title') || element.getAttribute('name') || tag);
    }
    return clean(
      element.getAttribute('data-ga4-label') ||
      element.getAttribute('aria-label') ||
      element.getAttribute('title') ||
      element.innerText ||
      element.textContent ||
      element.getAttribute('name') ||
      element.getAttribute('id') ||
      tag
    );
  }

  function getClasses(element) {
    if (!element || !element.classList) return '';
    return clean(Array.prototype.slice.call(element.classList, 0, 6).join(' '));
  }

  function getTargetPath(element) {
    var parts = [];
    var current = element;
    while (current && current.nodeType === 1 && current !== document.body && parts.length < 5) {
      var part = (current.tagName || '').toLowerCase();
      var id = current.getAttribute('id');
      var testId = current.getAttribute('data-testid') || current.getAttribute('data-test') || current.getAttribute('data-ga4-id');
      if (id) {
        part += '#' + clean(id, 60);
        parts.unshift(part);
        break;
      }
      if (testId) part += '[data-id="' + clean(testId, 60) + '"]';
      var classes = getClasses(current).split(' ').filter(Boolean).slice(0, 2);
      if (classes.length) part += '.' + classes.join('.');
      parts.unshift(part);
      current = current.parentElement;
    }
    return clean(parts.join(' > '), 220);
  }

  function sendClickEvent(element) {
    if (typeof gtag !== 'function') return;
    var tag = (element.tagName || '').toLowerCase();
    var params = {
      event_category: 'engagement',
      element_type: tag,
      element_id: clean(element.getAttribute('id')),
      element_name: clean(element.getAttribute('name')),
      element_role: clean(element.getAttribute('role')),
      element_classes: getClasses(element),
      element_label: getLabel(element),
      click_target: getTargetPath(element),
      page_path: clean(window.location.pathname, 220)
    };

    if (tag === 'input') params.input_type = clean(element.getAttribute('type') || 'text');

    var href = element.getAttribute('href') || element.href;
    if (href) {
      try {
        var url = new URL(href, window.location.href);
        params.link_url = clean(url.href, 500);
        params.link_domain = clean(url.hostname);
        params.outbound = url.hostname !== window.location.hostname ? 'true' : 'false';
      } catch (error) {
        params.link_url = clean(href, 500);
      }
    }

    try {
      gtag('event', 'site_click', params);
    } catch (error) {
      // Analytics should never interfere with the page.
    }
  }

  document.addEventListener('click', function (event) {
    if (!event.target || !event.target.closest) return;
    var element = event.target.closest(trackableSelector);
    if (!element || !document.documentElement.contains(element)) return;
    sendClickEvent(element);
  }, true);
})();
</script>
</head>
<body>
<header class="topbar">
  <div class="brand">
    <div class="brandTitle" id="title">Trilogy Magnetism Quiz</div>
    <div class="brandSub" id="subtitle">Magnetism & electromagnetism (Trilogy) • random sets • mark-scheme style feedback</div>
  </div>
  <div class="panelMeta">
    <span class="pill" id="statusPill">Idle</span>
    <span class="pill">Enter submits (Shift+Enter = new line)</span>
    <span class="pill">Units are case‑sensitive</span>
  </div>

  <div class="topStats" id="topStats">
    <span class="statPill"><b>Set</b> <span id="statSet">–</span></span>
    <span class="statPill"><b>Overall</b> <span id="statOverall">–</span></span>
    <button class="btn mini" id="resetOverallBtn" type="button" title="Reset overall stats (this device only)">Reset overall</button>
    <button class="btn mini" id="resetDeckBtn" type="button" title="Reset shuffle-deck (this device only)">Reset deck</button>
  </div>
</header>

    <div><b>Overall:</b> <span id="scoreBarOverall">–</span></div>
    <button class="btn mini" id="resetOverallBtn" type="button" title="Reset overall stats (this device only)">Reset overall</button>
    <button class="btn mini" id="resetDeckBtn" type="button" title="Reset shuffle-deck (this device only)">Reset deck</button>
  </div>
  <div class="small">Overall is stored on this device (browser local storage), not online.</div>
</div>


<main class="wrap">
  <section class="panel">
    <div class="panelTop">
      <div class="panelTitle">Controls</div>
      <div class="panelMeta">
        <span class="pill" id="setPill">No set</span>
      </div>
    </div>

    <div class="controls">
      <div class="control">
        <label for="numQ">Questions per set</label>
        <input id="numQ" type="number" min="5" max="40" value="14" />
      </div>
      <div class="control">
        <label for="diffMix">Difficulty mix</label>
        <select id="diffMix">
          <option value="all" selected>Mixed</option>
          <option value="easy">Mostly easier</option>
          <option value="med">Mostly medium</option>
          <option value="hard">Harder</option>
        </select>
      </div>

      <div class="control wide">
        <details class="topicDetails" id="topicDetails">
  <summary>Topics to include (click to expand/collapse)</summary>
  <div class="topicGrid">
    <label class="topic"><input class="topicCb" type="checkbox" value="units" checked /> Units & key quantities (A, V, W, N, T, m)</label>

    <label class="topic"><input class="topicCb" type="checkbox" value="poles" checked /> Poles: attraction/repulsion, non‑contact force</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="induced" checked /> Permanent vs induced magnetism</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="fields" checked /> Magnetic fields & field lines</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="compass" checked /> Compasses & Earth’s magnetic field</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="plotting" checked /> Practical: plotting field patterns</label>

    <label class="topic"><input class="topicCb" type="checkbox" value="wirefield" checked /> Field around a current‑carrying wire (RH grip rule)</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="solenoid" checked /> Solenoids & electromagnets (iron core)</label>

    <label class="topic"><input class="topicCb" type="checkbox" value="motoreffect" checked /> Motor effect (qualitative)</label>

    <label class="topic"><input class="topicCb" type="checkbox" value="flhr" checked /> Fleming’s left‑hand rule (HT)</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="bil" checked /> Motor‑effect force calculations: F = B I l (HT)</label>
    <label class="topic"><input class="topicCb" type="checkbox" value="motors" checked /> Electric motors (HT)</label>
  </div>
</details>
        <div class="hint">
          Notes: written answers are auto-checked for keywords only (not AI marking). “Start set” applies your current settings; “New random set” generates another set with the same settings. Overall stats are stored on this device only. (HT topics are included if you leave their boxes ticked.)
        </div>
      </div>

      <div class="control actions">
        <button class="btn primary" id="startBtn">Start set</button>
        <button class="btn" id="newSetBtn" disabled>New random set</button>
        <button class="btn" id="revealAllBtn" disabled>Reveal mark scheme</button>
      </div>

      <div class="control wide">
        <div class="kpis">
          <div class="kpi"><div class="kpiN" id="kpiChecked">0</div><div class="kpiL">checked</div></div>
          <div class="kpi"><div class="kpiN" id="kpiFull">0</div><div class="kpiL">full</div></div>
          <div class="kpi"><div class="kpiN" id="kpiPartial">0</div><div class="kpiL">partial</div></div>
          <div class="kpi"><div class="kpiN" id="kpiWrong">0</div><div class="kpiL">wrong</div></div>
        </div>
        <div class="scoreLine" id="scoreLine">-</div>
        <div class="hint" id="summaryLine">Start a set to begin.</div>
      </div>
    </div>
  </section>

  <div id="reportBanner" class="reportBanner"></div>

  <section class="panel">
    <div class="panelTop">
      <div class="panelTitle">Questions</div>
      <div class="panelMeta">
        <span class="pill">Mark scheme style explanations</span>
      </div>
    </div>
    <div id="quiz"></div>
  </section>
</main>

<script src="questions.js"></script>
<script src="engine.js"></script>
</body>
</html>
